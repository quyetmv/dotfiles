{{- $name := get . "name" | default "" -}}
{{- $email := get . "email" | default "" -}}
{{- $githubUser := get . "github_user" | default "" -}}
{{- if or $name $email $githubUser }}
{{- if or $name $email }}
[user]
{{- if $name }}
  name = {{ $name }}
{{- end }}
{{- if $email }}
  email = {{ $email }}
{{- end }}

{{- end }}
{{- if $githubUser }}
[github]
  user = {{ $githubUser }}
{{- end }}
{{- end }}
