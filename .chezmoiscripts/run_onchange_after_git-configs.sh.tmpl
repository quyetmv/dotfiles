#!/usr/bin/env bash
# This script generates work-specific git configs dynamically
# based on the work_configs list in chezmoi data.

set -euo pipefail

{{- if hasKey . "work_configs" }}
{{- range $i, $config := .work_configs }}
{{- if $config.dir }}
echo "🔧 Generating git config for {{ $config.dir }} -> ~/.gitconfig-work-{{ (add $i 1) }}"
cat > "$HOME/.gitconfig-work-{{ (add $i 1) }}" <<EOF
# Generated by chezmoi - DO NOT EDIT DIRECTLY
[user]
  name = {{ $config.name | default $.name }}
  email = {{ $config.email | default $.email }}
EOF
{{- end }}
{{- end }}
{{- end }}
