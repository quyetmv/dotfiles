#!/usr/bin/env bash
# Install Homebrew if not already installed (macOS only)
# On Linux, packages are installed via apt + mise (see setup-linux.sh)

set -euo pipefail

{{ if eq .chezmoi.os "linux" -}}
echo "ℹ Skipping Homebrew on Linux (using apt + mise instead)"
exit 0
{{ end -}}

if command -v brew &>/dev/null; then
    echo "✓ Homebrew already installed"
    exit 0
fi

if ! xcode-select -p &>/dev/null; then
    echo "✗ Xcode Command Line Tools are required before installing Homebrew"
    echo "  Run: xcode-select --install"
    exit 1
fi

echo "📦 Installing Homebrew..."
/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

# Add Homebrew to PATH for this session
{{- if eq .chezmoi.arch "arm64" }}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{- else }}
eval "$(/usr/local/bin/brew shellenv)"
{{- end }}

echo "✓ Homebrew installed successfully"
