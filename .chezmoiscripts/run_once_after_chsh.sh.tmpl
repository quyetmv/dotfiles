#!/usr/bin/env bash
# Change default shell to zsh automatically

set -euo pipefail

if command -v zsh >/dev/null 2>&1; then
    ZSH_BIN="$(command -v zsh)"
    if [[ "$SHELL" != "$ZSH_BIN" ]]; then
        echo "🔄 Changing default shell to zsh for $USER..."
        
        # Adding zsh to /etc/shells if not present
        if ! grep -q "$ZSH_BIN" /etc/shells; then
            echo "$ZSH_BIN" | sudo tee -a /etc/shells >/dev/null
        fi

        # Use sudo to bypass password prompt since we configured NOPASSWD in setup-linux.sh
        sudo chsh -s "$ZSH_BIN" "$USER"
        
        echo "✅ Default shell changed to zsh. Please restart your terminal!"
    else
        echo "ℹ Default shell is already zsh."
    fi
else
    echo "⚠️  zsh not found. Skipping default shell change."
fi
