{{- if eq .chezmoi.os "linux" -}}
# Linux-specific environment variables and settings
export DEBIAN_FRONTEND=noninteractive

# WSL-specific settings
if [[ -f /proc/sys/fs/binfmt_misc/WSLInterop ]]; then
    export IS_WSL=true
    # Open Windows browser from WSL
    if command -v explorer.exe >/dev/null 2>&1; then
        export BROWSER=explorer.exe
    fi
fi

# Keyring and SSH Agent
# Persist agent info so it is reused across sessions instead of
# spawning a new process (and leaking it) on every new shell.
if [[ -z "$SSH_AUTH_SOCK" ]]; then
    SSH_ENV="$HOME/.ssh/agent-env"
    if [[ -f "$SSH_ENV" ]]; then
        source "$SSH_ENV" > /dev/null
    fi
    if ! kill -0 "${SSH_AGENT_PID:-}" 2>/dev/null; then
        ssh-agent > "$SSH_ENV"
        chmod 600 "$SSH_ENV"
        source "$SSH_ENV" > /dev/null
    fi
fi

# Clipboard (requires xclip)
if command -v xclip >/dev/null 2>&1; then
    alias pbcopy='xclip -selection clipboard'
    alias pbpaste='xclip -selection clipboard -o'
fi
{{- end -}}
