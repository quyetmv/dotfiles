# NPM Install
alias n="npm"
alias ni="npm ci"
alias nid="npm install -D"
alias nig="npm install -g"
alias nu="npm uninstall"

# Node Runtime Info
alias nvl="node --version && npm --version"

# NPM Run Scripts
alias nr="npm run"
alias ns="npm start"
alias nss="npm run start-ssl"
alias nd="npm run dev"
alias nb="npm run build"
alias nt="npm run test"
alias ntw="npm run test:watch"
alias nc="npm run coverage"
alias nl="npm run lint"

# NPM Workspace
alias nw="npm workspace"
alias nwa="npm workspaces"
alias nwr="npm workspace run"
alias nwar="npm workspaces run"

# NPM Info
alias nls="npm list --depth=0"
alias nlsg="npm list -g --depth=0"
alias nv="npm version"

# NPM Maintenance
alias np="npm publish"

# HTTP Server
alias hs="http-server"
