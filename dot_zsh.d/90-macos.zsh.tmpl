{{- if eq .chezmoi.os "darwin" -}}
# Homebrew
alias b="brew"
alias bt="brew tap"
alias bi="brew install"
alias brm="brew uninstall"
alias bu="brew -v update; brew upgrade --force-bottle; brew cleanup; brew doctor"
alias bc='brew install --cask'

export HOMEBREW_CASK_OPTS="--appdir=/Applications"

# Lock the screen
alias afk="/System/Library/CoreServices/Menu\ Extras/User.menu/Contents/Resources/CGSession -suspend"

# Claude CLI
if [[ -n "${HOMEBREW_PREFIX:-}" && -x "${HOMEBREW_PREFIX}/bin/claude" ]]; then
    alias claude="${HOMEBREW_PREFIX}/bin/claude"
    alias cc="${HOMEBREW_PREFIX}/bin/claude"
fi
{{- end -}}
